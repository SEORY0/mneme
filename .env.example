# Copy to .env and fill in the secrets. .env is gitignored.
# Secrets:
ANTHROPIC_API_KEY=          # Claude Agent SDK (main agent loop)
OPENAI_API_KEY=             # GPT-5.5 hard-failure specialist

# CyberGym official verify key (matches the running submission server).
# Defaults to cybergym's built-in key when the server is started without an override.
CYBERGYM_API_KEY=

# CyberGym harness config (point at your local install):
CYBERGYM_SERVER_URL=http://127.0.0.1:8666
CYBERGYM_DATA_DIR=/data/cybergym_data/data
CYBERGYM_MASK_MAP=/home/nsd/cybergym/mask_map.json
CYBERGYM_PYTHON=/home/nsd/anaconda3/envs/cybergym/bin/python
CYBERGYM_SRC=/home/nsd/cybergym/src

# Optional:
# MEMONAEMO_SPECIALIST_MODEL=gpt-5.5
